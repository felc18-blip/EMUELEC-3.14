Fix dtc-lexer yylloc multiple-definition linker error with GCC 10+.

GCC 10+ defaults to -fno-common which rejects multiple tentative definitions
of the same symbol across translation units. Both scripts/dtc/dtc-lexer.l
and scripts/dtc/dtc-parser.tab.o define `YYLTYPE yylloc;` at file scope, so
linking dtc now fails:

  ld: scripts/dtc/dtc-parser.tab.o:(.bss+0x50): multiple definition of `yylloc';
      scripts/dtc/dtc-lexer.lex.o:(.bss+0x0): first defined here

Declare the lexer's copy as `extern` in both the .l source and the shipped
pre-generated .lex.c_shipped (the kernel's `cmd,shipped` rule copies this
shipped file over dtc-lexer.lex.c at build time — we must patch the source
AND the shipped copy to prevent the unpatched version from being restored).

diff --git a/scripts/dtc/dtc-lexer.l b/scripts/dtc/dtc-lexer.l
--- a/scripts/dtc/dtc-lexer.l
+++ b/scripts/dtc/dtc-lexer.l
@@ -39,7 +39,7 @@ LINECOMMENT	"//".*\n

 #include "dtc-parser.tab.h"

-YYLTYPE yylloc;
+extern YYLTYPE yylloc;

 /* CAUTION: this will stop working if we ever use yyless() or yyunput() */
 #define	YY_USER_ACTION \
diff --git a/scripts/dtc/dtc-lexer.lex.c_shipped b/scripts/dtc/dtc-lexer.lex.c_shipped
--- a/scripts/dtc/dtc-lexer.lex.c_shipped
+++ b/scripts/dtc/dtc-lexer.lex.c_shipped
@@ -637,7 +637,7 @@
 #include "srcpos.h"
 #include "dtc-parser.tab.h"

-YYLTYPE yylloc;
+extern YYLTYPE yylloc;

 /* CAUTION: this will stop working if we ever use yyless() or yyunput() */
 #define	YY_USER_ACTION \
