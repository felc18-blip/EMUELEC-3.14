# Adaptado para NextOS Elite Edition (Amlogic Kernel 3.14 & NG)

help() {
  echo "NextOS Elite EDID Manager"
  echo ""
  echo "Uso: getedid {create|delete|gpu|help}"
}

# Detecta se é Amlogic-old (3.14) ou Amlogic-ng (DRM)
check_gpu() {
  if [ -f "/sys/devices/virtual/amhdmitx/amhdmitx0/rawedid" ]; then
    gpu="Amlogic-old (Kernel 3.14)"
    mode="legacy"
  elif [ -d "/sys/class/drm/card0-HDMI-A-1" ]; then
    gpu="Amlogic-ng (DRM/KMS)"
    mode="drm"
  else
    echo "Erro: Hardware de vídeo não suportado ou driver não carregado."
    exit 1
  fi
}

mount_rw() { mount -o remount,rw /flash; }
mount_ro() { mount -o remount,ro /flash; }

sys_reboot() {
  mount_ro
  echo "Configuração aplicada. Reiniciando em 10 segundos..."
  sleep 10
  reboot
}

# Busca o arquivo de boot (uEnv.ini ou extlinux.conf)
check_file() {
  if [ -f "/flash/extlinux/extlinux.conf" ]; then
    file="/flash/extlinux/extlinux.conf"
    tag="APPEND"
  elif [ -f "/flash/uEnv.ini" ]; then
    file="/flash/uEnv.ini"
    tag="bootargs"
  else
    echo "Erro: Arquivo de boot não encontrado (/flash/uEnv.ini ou extlinux.conf)."
    exit 2
  fi
}

create_edid() {
  mkdir -p /storage/.config/firmware/edid
  mkdir -p /tmp/cpio/lib/firmware/edid

  if [ "$mode" = "legacy" ]; then
    echo "Capturando EDID Hexadecimal (Amlogic-old)..."
    RAW_HEX=$(cat "/sys/devices/virtual/amhdmitx/amhdmitx0/rawedid" | tr -d '\n' | tr -d ' ')
    printf "$(echo $RAW_HEX | sed 's/../\\x&/g')" > /tmp/cpio/lib/firmware/edid/edid.bin
  else
    echo "Capturando EDID Binário (Amlogic-ng)..."
    cat "/sys/class/drm/card0-HDMI-A-1/edid" > /tmp/cpio/lib/firmware/edid/edid.bin
  fi

  cp /tmp/cpio/lib/firmware/edid/edid.bin /storage/.config/firmware/edid/edid.bin

  # Cria o arquivo CPIO para o initrd
  cd /tmp/cpio/
  find . | cpio -o -H newc > /storage/edid.cpio 2>/dev/null
  echo "Arquivo EDID criado em /storage/edid.cpio"
}

run_create() {
  check_gpu
  check_file

  if grep -q "edid.cpio" "$file"; then
    echo "O arquivo $file já parece estar modificado. Use 'delete' primeiro."
    exit 5
  fi

  create_edid

  mount_rw
  cp /storage/edid.cpio /flash/edid.cpio
  cp "$file" "$file".old

  # Injeta os parâmetros de boot
  sed -i "/$tag/s/$/ initrd=\/edid.cpio drm.edid_firmware=edid\/edid.bin video=HDMI-A-1:D/" "$file"

  sys_reboot
}

del_edid() {
  check_file
  if [ -f "$file".old ]; then
    mount_rw
    mv "$file".old "$file"
    rm -f /flash/edid.cpio
    rm -rf /storage/.config/firmware/edid
    echo "Configurações removidas."
    sys_reboot
  else
    echo "Nenhum backup encontrado para restaurar."
    exit 3
  fi
}

case "$1" in
  'create') run_create ;;
  'gpu')    check_gpu; echo "GPU Detectada: $gpu" ;;
  'delete') del_edid ;;
  'help')   help ;;
  *)        echo "Uso: $0 {create|gpu|delete|help}" ;;
esac
