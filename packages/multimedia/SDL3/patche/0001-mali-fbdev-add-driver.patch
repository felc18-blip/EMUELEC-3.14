diff --git a/CMakeLists.txt b/CMakeLists.txt
--- a/CMakeLists.txt
+++ b/CMakeLists.txt
@@
 set_option(SDL_VIVANTE             "Use Vivante EGL video driver" ${UNIX_SYS})
+set_option(SDL_MALI                "Use Mali EGL fbdev video driver" ${UNIX_SYS})

@@
     CheckVivante()
+    CheckMali()

diff --git a/cmake/sdlchecks.cmake b/cmake/sdlchecks.cmake
--- a/cmake/sdlchecks.cmake
+++ b/cmake/sdlchecks.cmake
@@
 endmacro()

+macro(CheckMali)
+  if(SDL_MALI)
+    check_c_source_compiles("
+        #define LINUX
+        #define EGL_API_FB
+        #include <EGL/egl.h>
+        int main(int argc, char** argv) { return 0; }"
+        HAVE_VIDEO_MALI_EGL_FB)
+
+    if(HAVE_VIDEO_MALI_EGL_FB)
+      set(SDL_VIDEO_DRIVER_MALI 1)
+      set(HAVE_SDL_VIDEO TRUE)
+
+      file(GLOB MALI_SOURCES
+        ${CMAKE_CURRENT_SOURCE_DIR}/src/video/mali-fbdev/*.c
+      )
+
+      list(APPEND SDL_VIDEO_SOURCES ${MALI_SOURCES})
+
+      add_definitions(-DLINUX -DEGL_API_FB)
+      list(APPEND EXTRA_LIBS EGL)
+    endif()
+  endif()
+endmacro()

diff --git a/include/SDL_config.h.cmake b/include/SDL_config.h.cmake
--- a/include/SDL_config.h.cmake
+++ b/include/SDL_config.h.cmake
@@
 #cmakedefine SDL_VIDEO_DRIVER_VIVANTE @SDL_VIDEO_DRIVER_VIVANTE@
+#cmakedefine SDL_VIDEO_DRIVER_MALI @SDL_VIDEO_DRIVER_MALI@

diff --git a/src/video/SDL_egl.c b/src/video/SDL_egl.c
--- a/src/video/SDL_egl.c
+++ b/src/video/SDL_egl.c
@@
-#elif defined(SDL_VIDEO_DRIVER_ANDROID) || defined(SDL_VIDEO_DRIVER_VIVANTE)
+#elif defined(SDL_VIDEO_DRIVER_ANDROID) || defined(SDL_VIDEO_DRIVER_VIVANTE) || defined(SDL_VIDEO_DRIVER_MALI)

diff --git a/src/video/SDL_sysvideo.h b/src/video/SDL_sysvideo.h
--- a/src/video/SDL_sysvideo.h
+++ b/src/video/SDL_sysvideo.h
@@
 extern VideoBootStrap VIVANTE_bootstrap;
+extern VideoBootStrap MALI_bootstrap;

diff --git a/src/video/SDL_video.c b/src/video/SDL_video.c
--- a/src/video/SDL_video.c
+++ b/src/video/SDL_video.c
@@
 #ifdef SDL_VIDEO_DRIVER_VIVANTE
     &VIVANTE_bootstrap,
 #endif
+#ifdef SDL_VIDEO_DRIVER_MALI
+    &MALI_bootstrap,
+#endif
