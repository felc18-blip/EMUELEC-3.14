+             * just stick with the original (possibly smaller) fb size.
+             */
+            int sysfs_w = 0, sysfs_h = 0;
+            if (MALI_GetDisplayModeFromSysfs(&sysfs_w, &sysfs_h) &&
+                (sysfs_w > (int)vinfo.xres || sysfs_h > (int)vinfo.yres)) {
+                SDL_LogInfo(SDL_LOG_CATEGORY_VIDEO,
