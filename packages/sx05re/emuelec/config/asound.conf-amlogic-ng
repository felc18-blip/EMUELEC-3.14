pcm.dmix_hw {
    type dmix
    ipc_key 1024
    ipc_perm 0666
    slave {
        pcm "hw:0,0"
        rate 48000
        channels 2
	    period_size 1024
	    buffer_size 4096
    }
}

pcm.!default {
    type softvol
    slave.pcm "dmix_hw"
    control {
        name "Music"
        card 0
    }
    max_dB 12.0
    min_dB -50.0
}

ctl.!default {
    type hw
    card 0
}
