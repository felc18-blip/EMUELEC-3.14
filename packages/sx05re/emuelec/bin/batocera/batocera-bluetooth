#!/bin/bash

. /etc/profile

ACTION=$1
shift

LIVE_PIDFILE="/tmp/bt_live_scan.pid"
LIVE_SEENFILE="/tmp/bt_live_seen.txt"

do_help() {
    echo "${1} list" >&2
    echo "${1} trust" >&2
    echo "${1} remove <device address>" >&2
    echo "${1} enable" >&2
    echo "${1} disable" >&2
    echo "${1} connect <device address>" >&2
    echo "${1} disconnect <device address>" >&2
    echo "${1} live_devices" >&2
    echo "${1} stop_live_devices" >&2
    echo "${1} forgetBT" >&2
}

# Envia comando pro bluetoothctl via stdin pipe. Bluez 5.86 em Amlogic-old
# retorna vazio em `bluetoothctl <cmd>` direto não-interativo; enviar via
# stdin (o que equivale ao modo interativo) funciona. Timeout protege contra
# travamentos do daemon.
btctl() {
    local input="$1"
    local tmout="${2:-10}"
    printf '%s\nquit\n' "$input" | timeout "$tmout" bluetoothctl 2>/dev/null
}

do_list() {
    find /storage/.cache/bluetooth -type f -name info 2>/dev/null |
	while read FILE
	do
	    if grep -qE '^Trusted=true$' "${FILE}"
	    then
		DEVNAME=$(grep -E '^Name=' "${FILE}" | sed -e s+"^Name="++)
		DEVADDR=$(basename $(dirname "${FILE}"))
		echo "${DEVADDR} ${DEVNAME}"
	    fi
	done
}

do_remove() {
    local DEV="${1}"
    btctl "untrust ${DEV}
remove ${DEV}" 10 >> /emuelec/logs/bluetooth.log 2>&1
    return $?
}

do_trust() {
	local LEGACY=$(get_ee_setting ee_bluetooth_legacy.enabled)
	if [[ "$LEGACY" == "1" ]]; then
		emuelec-bluetooth-legacy
	else
		emuelec-bluetooth
	fi
}

do_enable() {
    btctl "power on
agent on
default-agent" 5 >/dev/null
    return 0
}

do_disable() {
    do_stop_live_devices >/dev/null 2>&1
    btctl "power off" 5 >/dev/null
    return 0
}

do_connect() {
    local DEV="${1}"
    btctl "connect ${DEV}" 15 >/dev/null
    if btctl "info ${DEV}" 5 | grep -q "Connected: yes"; then
        return 0
    fi
    return 1
}

do_disconnect() {
    local DEV="${1}"
    btctl "disconnect ${DEV}" 10 >/dev/null
    return 0
}

do_forgetBT() {
    # Remove todos os devices conhecidos (trusted + descobertos)
    local DEVS
    DEVS=$(btctl "devices" 5 | awk '/^Device/ {print $2}')
    for MAC in $DEVS; do
        btctl "untrust ${MAC}
disconnect ${MAC}
remove ${MAC}" 10 >/dev/null
    done
    return 0
}

# Mapeia Icon/Class do bluez pro type que a ES usa como ícone.
# Tipos aceitos pela ES: joystick, audio, keyboard, mouse, phone, computer, unknown
_device_type() {
    local INFO="$1"
    local ICON CLAZZ
    ICON=$(echo "$INFO" | awk -F': ' '/^[[:space:]]*Icon:/ {print $2; exit}')
    CLAZZ=$(echo "$INFO" | awk -F': ' '/^[[:space:]]*Class:/ {print $2; exit}')

    case "$ICON" in
        input-gaming|input-joystick) echo "joystick"; return;;
        audio-headphones|audio-headset|audio-card|audio-speakers) echo "audio"; return;;
        input-keyboard) echo "keyboard"; return;;
        input-mouse) echo "mouse"; return;;
        phone) echo "phone"; return;;
        computer) echo "computer"; return;;
    esac

    # Fallback por Class: byte central indica major device class
    # 0x000 5xx = peripheral (joystick/keyboard/mouse)
    # 0x000 4xx = audio/video
    case "$CLAZZ" in
        0x00*5*) echo "joystick"; return;;
        0x00*4*) echo "audio"; return;;
    esac

    echo "unknown"
}

_emit_device() {
    local MAC="$1"
    local STATUS="$2"
    local INFO NAME TYPE
    INFO=$(btctl "info $MAC" 5)
    NAME=$(echo "$INFO" | awk -F': ' '/^[[:space:]]*Name:/ {print $2; exit}')
    [[ -z "$NAME" ]] && NAME="$MAC"
    TYPE=$(_device_type "$INFO")
    # escape xml
    NAME="${NAME//&/&amp;}"
    NAME="${NAME//\"/&quot;}"
    echo "<device id=\"${MAC}\" name=\"${NAME}\" status=\"${STATUS}\" type=\"${TYPE}\"/>"
}

do_live_devices() {
    do_stop_live_devices >/dev/null 2>&1

    # bluetoothctl em sessão persistente via sleep no stdin — mantém scan ligado
    (printf 'power on\nagent on\ndefault-agent\ndiscoverable on\npairable on\nscan on\n' ; sleep 9999) |
        bluetoothctl >/dev/null 2>&1 &
    echo $! > "$LIVE_PIDFILE"

    : > "$LIVE_SEENFILE"

    trap 'do_stop_live_devices; exit 0' TERM INT

    while [[ -f "$LIVE_PIDFILE" ]] && kill -0 "$(cat "$LIVE_PIDFILE" 2>/dev/null)" 2>/dev/null; do
        local CURRENT
        CURRENT=$(btctl "devices" 5 | awk '/^Device/ {print $2}')

        # Novos → added (só se já tem Name, filtra noise "TY")
        for MAC in $CURRENT; do
            if ! grep -qx "$MAC" "$LIVE_SEENFILE" 2>/dev/null; then
                local NAME
                NAME=$(btctl "info $MAC" 5 | awk -F': ' '/^[[:space:]]*Name:/ {print $2; exit}')
                if [[ -n "$NAME" ]] && [[ "$NAME" != "TY" ]]; then
                    _emit_device "$MAC" "added"
                    echo "$MAC" >> "$LIVE_SEENFILE"
                fi
            fi
        done

        # Sumidos → removed
        if [[ -s "$LIVE_SEENFILE" ]]; then
            while read -r SEEN; do
                if ! echo "$CURRENT" | grep -qx "$SEEN"; then
                    _emit_device "$SEEN" "removed"
                    grep -vx "$SEEN" "$LIVE_SEENFILE" > "${LIVE_SEENFILE}.tmp" 2>/dev/null
                    mv "${LIVE_SEENFILE}.tmp" "$LIVE_SEENFILE" 2>/dev/null
                fi
            done < "$LIVE_SEENFILE"
        fi

        sleep 2
    done

    do_stop_live_devices
}

do_stop_live_devices() {
    if [[ -f "$LIVE_PIDFILE" ]]; then
        local PID
        PID=$(cat "$LIVE_PIDFILE" 2>/dev/null)
        if [[ -n "$PID" ]]; then
            pkill -P "$PID" 2>/dev/null
            kill "$PID" 2>/dev/null
        fi
        rm -f "$LIVE_PIDFILE"
    fi
    btctl "scan off" 3 >/dev/null 2>&1
    rm -f "$LIVE_SEENFILE"
    return 0
}

case "${ACTION}" in
    "list")              do_list ;;
    "trust")             do_trust ;;
    "remove")            do_remove "${1}" || exit 1 ;;
    "enable")            do_enable ;;
    "disable")           do_disable ;;
    "connect")           do_connect "${1}" || exit 1 ;;
    "disconnect")        do_disconnect "${1}" ;;
    "live_devices")      do_live_devices ;;
    "stop_live_devices") do_stop_live_devices ;;
    "forgetBT")          do_forgetBT ;;
    *)                   do_help "${0}"; exit 1 ;;
esac

exit 0
