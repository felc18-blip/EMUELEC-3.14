@@ -27,6 +27,19 @@
 #include "fast/interpreter.h"
 #include "ship/config/ConsoleVariable.h"
 
+#ifdef USE_OPENGLES
+// NextOS Mali-450 fork: GLES3/gl3.h declares these ES3 entry points, but
+// libGLESv2.so on Mali-450 does NOT implement them (Utgard is ES 2.0 only).
+// Macros redirect call sites to safe fallbacks so the linker is happy.
+// MSAA code never takes the multisampled branch with msaa_level<=1;
+// glReadBuffer in ES 2 defaults to GL_BACK; glBlitFramebuffer failure only
+// drops post-process effects.
+#define glRenderbufferStorageMultisample(target, samples, fmt, w, h) \
+    glRenderbufferStorage((target), (fmt), (w), (h))
+#define glBlitFramebuffer(...) ((void)0)
+#define glReadBuffer(src) ((void)(src))
+#endif
+
