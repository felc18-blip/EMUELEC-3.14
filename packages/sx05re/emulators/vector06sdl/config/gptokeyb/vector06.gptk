# NextOS vector06sdl — gamepad → keyboard
# Vector-06C uses keyboard for input. Common keys: Space, Enter, Esc, arrows.
back = esc
start = enter
guide = enter
a = space
b = ctrl
x = shift
y = alt
l1 = q
r1 = w
up = up
down = down
left = left
right = right
left_analog_up = up
left_analog_down = down
left_analog_left = left
left_analog_right = right
