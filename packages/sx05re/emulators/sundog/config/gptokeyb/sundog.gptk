# NextOS sundog — gamepad → mouse + teclas
# SunDog usa mouse principalmente. analog stick = mouse, A = click esquerdo
back = esc
start = enter
guide = enter
a = mouse_left
b = mouse_right
x = space
y = enter
left_analog_as_mouse = true
mouse_scale = 8192
up = up
down = down
left = left
right = right
