@@ -1,10 +1,84 @@
 #include <assert.h>
+#include <stdio.h>
+#include <stdlib.h>
+#include <string.h>
 #include <Log.h>
 #include <Graphics/OpenGLContext/opengl_Attributes.h>
 #include "glsl_Utils.h"
 
 using namespace glsl;
 
+// ---- NextOS shader-dump harness ----
+// Always-on (until removed). Writes shader source + glGetShaderInfoLog to
+// /storage/gliden64-shaderlog.txt (override via env GLIDEN64_SHADER_DUMP).
+// One file per session: truncated on first call.
+static FILE * nextos_dumpfp()
+{
+	static FILE * fp = nullptr;
+	static bool tried = false;
+	if (!tried) {
+		tried = true;
+		const char * path = getenv("GLIDEN64_SHADER_DUMP");
+		if (!path || !*path) path = "/storage/gliden64-shaderlog.txt";
+		fp = fopen(path, "w");
+		if (fp) {
+			fprintf(fp, "=== NextOS GLideN64 shader dump ===\n");
+			fflush(fp);
+		}
+	}
+	return fp;
+}
+
+void Utils::nextosDumpShader(GLuint _shader, GLenum _type, const char * _src)
+{
+	FILE * fp = nextos_dumpfp();
+	if (!fp) return;
+	GLint status = GL_FALSE;
+	glGetShaderiv(_shader, GL_COMPILE_STATUS, &status);
+	GLint logLen = 0;
+	glGetShaderiv(_shader, GL_INFO_LOG_LENGTH, &logLen);
+	const char * tname = (_type == GL_VERTEX_SHADER) ? "VERTEX" :
+		(_type == GL_FRAGMENT_SHADER) ? "FRAGMENT" : "OTHER";
+	fprintf(fp, "\n----- %s shader id=%u status=%s -----\n",
+		tname, (unsigned)_shader, status == GL_TRUE ? "OK" : "FAIL");
+	if (_src) fprintf(fp, "%s\n", _src);
+	if (logLen > 1) {
+		char * buf = (char*) malloc(logLen + 1);
+		if (buf) {
+			GLsizei got = 0;
+			glGetShaderInfoLog(_shader, logLen, &got, buf);
+			buf[got < logLen ? got : logLen] = 0;
+			fprintf(fp, "----- infolog -----\n%s\n", buf);
+			free(buf);
+		}
+	}
+	fflush(fp);
+}
+
+void Utils::nextosDumpProgram(GLuint _program, const char * _label)
+{
+	FILE * fp = nextos_dumpfp();
+	if (!fp) return;
+	GLint status = GL_FALSE;
+	glGetProgramiv(_program, GL_LINK_STATUS, &status);
+	GLint logLen = 0;
+	glGetProgramiv(_program, GL_INFO_LOG_LENGTH, &logLen);
+	fprintf(fp, "\n===== PROGRAM id=%u label=%s status=%s =====\n",
+		(unsigned)_program, _label ? _label : "(none)",
+		status == GL_TRUE ? "OK" : "FAIL");
+	if (logLen > 1) {
+		char * buf = (char*) malloc(logLen + 1);
+		if (buf) {
+			GLsizei got = 0;
+			glGetProgramInfoLog(_program, logLen, &got, buf);
+			buf[got < logLen ? got : logLen] = 0;
+			fprintf(fp, "----- link infolog -----\n%s\n", buf);
+			free(buf);
+		}
+	}
+	fflush(fp);
+}
