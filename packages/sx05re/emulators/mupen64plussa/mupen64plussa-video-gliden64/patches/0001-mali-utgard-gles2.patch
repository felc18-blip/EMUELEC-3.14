+		// NextOS: Mali-fbdev SDL2 sometimes doesn't make GL context current
+		// before plugin init runs. Default to GLES2 conservative path.
+		fprintf(stderr, "NextOS GLideN64: GL_VERSION is NULL — assuming GLES2 (Mali-Utgard fallback)\n");
+		fflush(stderr);
+		strDriverVersion = "OpenGL ES 2.0 (NextOS-fallback)";
