+			envForce ? envForce : "(unset)");
+		fflush(stderr);
+		if ((envForce && envForce[0] == '1') || maliUtgard) {
+			isGLES2 = true;
+			isGLESX = true;
+			fprintf(stderr, "NextOS GLideN64: FORCING GLES2 mode\n");
