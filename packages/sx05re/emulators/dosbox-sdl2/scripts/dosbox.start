# Copyright (C) 2018-present Frank Hartung (supervisedthinking (@) gmail.com)

# Source predefined functions and variables
. /etc/profile

set_audio pulseaudio

# Set common variables
RR_DOSBOX_HOME=/storage/.dosbox
RR_DOSBOX_HOME_CONFIG=/storage/.config/dosbox

# Create symlink to config dir
if [ ! -L ${RR_DOSBOX_HOME} ]; then
  if [ -d ${RR_DOSBOX_HOME} ]; then
    cp -rf ${RR_DOSBOX_HOME} ${RR_DOSBOX_HOME_CONFIG}
    rm -rf ${RR_DOSBOX_HOME}
  fi
  ln -sf ${RR_DOSBOX_HOME_CONFIG} ${RR_DOSBOX_HOME}
fi

# NextOS: gptokeyb traduz gamepad → teclado (DOS espera input keyboard).
# Select+Start = kill (sai do jogo).
GPTK_CFG=/emuelec/configs/gptokeyb/dosbox.gptk
if [ -f "$GPTK_CFG" ] && [ -x /usr/bin/gptokeyb ]; then
  /usr/bin/gptokeyb -1 dosbox -c "$GPTK_CFG" &
  GPTK_PID=$!
  trap "kill $GPTK_PID 2>/dev/null" EXIT
fi

# Run the emulator
dosbox "$@" > /emuelec/logs/dosbox.log 2>&1
[ -n "$GPTK_PID" ] && kill "$GPTK_PID" 2>/dev/null

set_audio default
